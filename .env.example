# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# Orange Pi SSH deploy target
ORANGEPI_HOST=192.168.1.93
ORANGEPI_USER=root
ORANGEPI_SSH_KEY=~/.ssh/orangepi_key

# OpenWeatherMap (optional - project uses Open-Meteo which is keyless)
OPENWEATHER_API_KEY=your_key_here

# RadioBrowser API (no key needed, public API)
# RADIOBROWSER_HOST=de1.api.radio-browser.info

# Home Assistant (if enabled)
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your_long_lived_token_here

# Netdata (if enabled, usually no auth on LAN)
NETDATA_URL=http://localhost:19999
