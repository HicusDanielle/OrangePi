[Unit]
Description=Orange Pi Control Center — Flask Applications
Documentation=https://github.com/your-repo/OrangePI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/orangepi/apps
ExecStart=/usr/bin/bash /opt/orangepi/scripts/start_all.sh
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=orangepi-apps

[Install]
WantedBy=multi-user.target
